{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash|Read|Edit|Write|Grep|Glob",
        "hooks": [
          {
            "type": "command",
            "command": "bash -c 'GUARD=$(find ~/.claude/plugins/cache -path \"*/claude-guard/*/claude-guard.sh\" 2>/dev/null | head -1); [ -x \"$GUARD\" ] && exec \"$GUARD\" || cat >/dev/null'"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "bash -c 'AUDIT=$(find ~/.claude/plugins/cache -path \"*/claude-guard/*/audit-log.sh\" 2>/dev/null | head -1); [ -x \"$AUDIT\" ] && exec \"$AUDIT\" || cat >/dev/null'"
          }
        ]
      }
    ]
  }
}
